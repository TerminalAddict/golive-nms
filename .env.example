GOLIVE_VERSION=latest
GOLIVE_DOMAIN=localhost
GOLIVE_WEB_PORT=8443
GOLIVE_COLLECTOR_PORT=9443
POSTGRES_DB=golive
POSTGRES_USER=golive
POSTGRES_PASSWORD=change-me-before-production
GOLIVE_ENCRYPTION_KEY=change-me-to-a-random-32-byte-value
GOLIVE_ADMIN_EMAIL=admin@example.com
GOLIVE_ADMIN_PASSWORD=change-me-now
GOLIVE_AGENT_TOKEN=change-me-to-a-long-random-agent-token
GOLIVE_MONIT_USERNAME=monit
GOLIVE_MONIT_PASSWORD=change-me-to-a-long-random-monit-password
GOLIVE_SYSLOG_PORT=5514
GOLIVE_TRAP_PORT=1162
GOLIVE_BACKUP_PASSPHRASE=change-me-to-a-long-random-backup-passphrase
GOLIVE_BACKUP_INTERVAL=24h
GOLIVE_BACKUP_KEEP=10
# PostgreSQL samples/events/audit/remediation history retention
GOLIVE_RETENTION_DAYS=395
# Optional OpenID Connect SSO
GOLIVE_OIDC_ISSUER=
GOLIVE_OIDC_CLIENT_ID=
GOLIVE_OIDC_CLIENT_SECRET=
GOLIVE_OIDC_REDIRECT_URL=https://nms.example.com/api/v1/auth/oidc/callback
